# ─────────────────────────────────────────────────────────────────────────────
# NutriBot — Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control
# ─────────────────────────────────────────────────────────────────────────────

# IBM Cloud API Key (required)
# Get from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=cRwESUGCQEvVZZtOpud9gurWAmTYNEKbqKMegQs0cNCk

# IBM Watsonx.ai Project ID (required)
# Get from: https://dataplatform.cloud.ibm.com → Your Project → Manage → General
WATSONX_PROJECT_ID=26f0031d-f846-49dc-a049-d960bbd89390

# Watsonx.ai Service URL (default: us-south)
# Options: us-south, eu-de, eu-gb, jp-tok, au-syd
WATSONX_URL=https://eu-gb.ml.cloud.ibm.com

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_DEBUG=false

# Server Port
PORT=5001
