# ─────────────────────────────────────────────────────────────────────────────
# FarmBot — Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control
# ─────────────────────────────────────────────────────────────────────────────

# IBM Cloud API Key (required)
# Get from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your-ibm-cloud-api-key-here

# IBM Watsonx.ai Project ID (required)
# Get from: https://dataplatform.cloud.ibm.com → Your Project → Manage → General
WATSONX_PROJECT_ID=your-watsonx-project-id-here

# Watsonx.ai Service URL (default: us-south)
# Options: us-south, eu-de, eu-gb, jp-tok, au-syd
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model ID — use one supported by your Watsonx environment
# Confirmed supported: meta-llama/llama-3-3-70b-instruct (recommended)
#                      meta-llama/llama-4-maverick-17b-128e-instruct-fp8
#                      mistralai/mistral-small-3-1-24b-instruct-2503
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_DEBUG=false

# Server Port
PORT=5000
